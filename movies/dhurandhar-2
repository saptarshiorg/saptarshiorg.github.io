  <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600;700&family=Google+Sans+Display:wght@400;500;700&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
  
  <style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; user-select: none; -webkit-tap-highlight-color: transparent; }

  :root {
    --accent: #00FF00;
    --accent2: #00FF00;
    --red: #f43f5e;
    --white: rgba(255,255,255,0.97);
    --dim: rgba(255,255,255,0.45);
    --dim2: rgba(255,255,255,0.25);
    --glass: transparent;
    --glass-b: transparent;
    --glass-hover: rgba(0,255,0,0.08);
    --panel-bg: rgba(17,50,28,0.97);
    --blur: blur(8px);
    --r: 14px;
    --ea-green: #00FF00;
    --ea-forest: #11321C;
  }

  /* ── SX SPORTS LOGO ── */
  #sx-logo { opacity: 0.82 !important; }
  #player.ui-visible #sx-logo { opacity: 1 !important; }

  html, body { width:100%; height:100%; background:#000; font-family:'Google Sans','Product Sans',Roboto,sans-serif; overflow:hidden; }

  #player {
    position:relative; width:100vw; height: 100vh; height: 100dvh; background:#000; overflow:hidden; cursor:none;
  }
  #player.show-cursor { cursor:default; }

  video {
    width:100%; height:100%; object-fit:contain; display:block; background:#000;
    will-change: transform; transform: translate3d(0,0,0); -webkit-transform: translate3d(0,0,0);
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    contain: strict; isolation: isolate; image-rendering: auto;
  }

  .grad-top {
    position:absolute; top:0; left:0; right:0; height:160px;
    background:linear-gradient(to bottom,rgba(0,0,0,0.82) 0%,transparent 100%);
    pointer-events:none; opacity:0; transition:opacity .35s; z-index:5;
  }
  .grad-bottom {
    position:absolute; bottom:0; left:0; right:0; height:260px;
    background:linear-gradient(to top,rgba(0,0,0,0.92) 0%,transparent 100%);
    pointer-events:none; opacity:0; transition:opacity .35s; z-index:5;
  }
  #player.ui-visible .grad-top, #player.ui-visible .grad-bottom { opacity:1; }

  /* ── SPINNER ── */
  #spinner { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); z-index:12; display:none; }
  #spinner.show { display:block; }
  #spinner svg { width:56px; height:56px; animation:spin .9s linear infinite; }
  @keyframes spin { to { transform:rotate(360deg); } }

  /* ── DOUBLE TAP RIPPLE ── */
  .dt-ripple { position:absolute; top:0; bottom:0; width:45%; display:flex; align-items:center; justify-content:center; pointer-events:none; z-index:19; opacity:0; flex-direction:column; gap:10px; }
  #dt-left  { left:0;  background:radial-gradient(ellipse at 25% 50%, rgba(0,255,0,0.18) 0%, transparent 68%); }
  #dt-right { right:0; background:radial-gradient(ellipse at 75% 50%, rgba(0,255,0,0.18) 0%, transparent 68%); }
  .dt-ripple .dt-icon { display:flex; gap:-4px; }
  .dt-ripple .dt-icon svg { width:28px; height:28px; fill:rgba(255,255,255,0.9); filter:drop-shadow(0 0 6px rgba(0,255,0,0.7)); }
  .dt-ripple .dt-label { font-size:14px; font-weight:700; color:#fff; letter-spacing:0.4px; text-shadow:0 1px 8px rgba(0,0,0,0.9); }
  .dt-ripple.flash { animation:dt-anim .5s ease forwards; }
  @keyframes dt-anim { 0%{opacity:0} 15%{opacity:1} 75%{opacity:1} 100%{opacity:0} }

  /* ── CENTER CLUSTER ── */
  #center-cluster { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); display:flex; align-items:center; gap:32px; z-index:20; opacity:0; transition:opacity .25s; pointer-events:none; }
  #center-cluster.visible { opacity:1; pointer-events:all; }
  .tap-side-btn { display:flex; flex-direction:column; align-items:center; gap:6px; cursor:pointer; transition:transform .12s; }
  .tap-side-btn:active { transform:scale(0.87); }
  .tap-circle { width:58px; height:58px; border-radius:50%; background: transparent; border: none; display:flex; align-items:center; justify-content:center; transition: background .15s; }
  .tap-side-btn:hover .tap-circle { background: rgba(0,255,0,0.1); }
  .tap-side-btn svg { width:24px; height:24px; fill:#ffffff; }
  .tap-label { font-size:11px; font-weight:700; color:rgba(255,255,255,0.75); letter-spacing:0.4px; }
  #center-btn { width:82px; height:82px; border-radius:50%; background: transparent; border: none; display:flex; align-items:center; justify-content:center; cursor:pointer; transition: background .15s, transform .12s; flex-shrink:0; }
  #center-btn:hover { background: rgba(0,255,133,0.12); }
  #center-btn:active { transform:scale(0.91); }
  #center-btn svg { width:32px; height:32px; fill:#00FF85; }
  #center-btn:not(.is-playing) svg { margin-left:4px; }

  /* ── CONTROLS ── */
  #controls { position:absolute; bottom:0; left:0; right:0; padding:0 12px 12px; z-index:25; opacity:0; transform:translateY(14px); transition:opacity .3s, transform .3s; pointer-events:none; }
  #player.ui-visible #controls { opacity:1; transform:translateY(0); pointer-events:all; }
  #ctrl-glass { background: transparent; border: none; padding: 8px 4px 10px; }

  /* ── PROGRESS BAR ── */
  #progress-wrap { width:100%; height:24px; display:flex; align-items:center; cursor:pointer; margin-bottom:10px; padding:0 2px; position:relative; }
  #progress-track { position:relative; width:100%; height:3.5px; background:rgba(255,255,255,0.14); border-radius:99px; transition:height .18s; }
  #progress-wrap:hover #progress-track, #progress-wrap.dragging #progress-track { height:6px; }
  #progress-buffer { position:absolute; left:0; top:0; height:100%; width:0; background:rgba(255,255,255,0.18); border-radius:99px; pointer-events:none; will-change:width; }
  #progress-fill { position:absolute; left:0; top:0; height:100%; width:0; background:linear-gradient(90deg, #11321C, #00FF00); border-radius:99px; pointer-events:none; will-change: width; }
  #progress-thumb { position:absolute; top:50%; left:0; width:15px; height:15px; border-radius:50%; background:#00FF00; transform:translate(0,-50%) scale(0); transition:transform .18s; pointer-events:none; box-shadow:0 0 10px rgba(0,255,0,0.95),0 0 0 3px rgba(0,255,0,0.22); will-change: transform; }
  #progress-wrap:hover #progress-thumb, #progress-wrap.dragging #progress-thumb { transform:translate(var(--thumb-x,0px),-50%) scale(1); }
  #time-tooltip { position:absolute; bottom:26px; background:rgba(6,8,20,0.9); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,0.13); color:#fff; font-size:11px; font-weight:600; font-family:'Roboto Mono',monospace; padding:4px 9px; border-radius:8px; pointer-events:none; display:none; transform:translateX(-50%); white-space:nowrap; }

  /* ── BOTTOM ROW ── */
  #bottom-row { display:flex; align-items:center; gap:5px; }
  .ctrl-btn { background: transparent; border: none; cursor: pointer; padding: 8px; border-radius: 11px; display: flex; align-items: center; justify-content: center; transition: color .15s, transform .12s, opacity .15s; flex-shrink: 0; color: rgba(255,255,255,0.85); }
  .ctrl-btn:hover { background: rgba(0,255,0,0.08); transform: scale(1.09); color: #fff; }
  .ctrl-btn:active { transform: scale(0.93); }
  .ctrl-btn svg { width: 20px; height: 20px; display: block; }
  .ctrl-btn.sm svg { width: 18px; height: 18px; }
  .ctrl-btn.btn-on { color: var(--ea-green); }

  /* volume */
  #vol-group { display:flex; align-items:center; gap:4px; }
  #vol-slider-wrap { width:0; overflow:hidden; transition:width .28s cubic-bezier(.4,0,.2,1); display:flex; align-items:center; }
  #vol-group:hover #vol-slider-wrap, #vol-group:focus-within #vol-slider-wrap { width:74px; }
  #vol-slider { -webkit-appearance:none; appearance:none; width:70px; height:3.5px; border-radius:99px; background:rgba(255,255,255,0.2); outline:none; cursor:pointer; }
  #vol-slider::-webkit-slider-thumb { -webkit-appearance:none; width:13px; height:13px; border-radius:50%; background:#00FF00; box-shadow:0 0 8px rgba(0,255,0,0.85); }

  /* time */
  #time-display { color:var(--dim); font-size:12px; font-weight:500; white-space:nowrap; padding:0 5px; letter-spacing:.3px; font-family:'Roboto Mono',monospace; }
  #time-display b { color:var(--white); font-weight:700; }
  .spacer { flex:1; }

  /* ── BADGES ── */
  #speed-badge, #quality-badge { font-size:10px; font-weight:700; color:var(--ea-green); background:rgba(0,255,0,0.08); border:1px solid rgba(0,255,0,0.25); border-radius:7px; padding:3px 7px; letter-spacing:.6px; cursor:pointer; transition:background .15s, transform .12s; }
  #speed-badge { display:none; }
  #speed-badge.visible { display:inline-block; }
  #speed-badge:hover, #quality-badge:hover { background:rgba(0,255,0,0.18); transform:scale(1.04); }
  #live-badge { font-size:10px; font-weight:700; letter-spacing:1.2px; color:#fff; background:rgba(255,0,122,0.75); border:1px solid rgba(255,0,122,0.5); backdrop-filter:blur(8px); border-radius:7px; padding:4px 9px; display:inline-flex; align-items:center; gap:5px; cursor:default; }
  #live-badge .live-dot { width:7px; height:7px; border-radius:50%; background:#fff; animation:live-pulse 1.6s ease-in-out infinite; }
  @keyframes live-pulse { 0%{box-shadow:0 0 0 0 rgba(255,0,122,0.75)} 60%{box-shadow:0 0 0 5px rgba(255,0,122,0)} 100%{box-shadow:0 0 0 0 rgba(255,0,122,0)} }

  /* ── SETTINGS PANEL ── */
  #settings-panel { position:absolute; bottom:90px; right:12px; background: rgba(0,0,0,0.28); backdrop-filter: blur(20px); border:1px solid rgba(255,255,255,0.08); border-radius:16px; padding:8px 0; min-width:200px; z-index:200; display:none; box-shadow:0 20px 60px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05); max-height:72vh; overflow-y:auto; }
  #settings-panel::-webkit-scrollbar { width:3px; }
  #settings-panel::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.15); border-radius:99px; }
  #settings-panel.open { display:block; animation:panel-in .18s cubic-bezier(.4,0,.2,1); }
  @keyframes panel-in { from{opacity:0;transform:translateY(8px) scale(0.97)} to{opacity:1;transform:none} }
  .setting-section { padding:8px 18px 4px; font-size:9px; font-weight:700; letter-spacing:1.6px; color:rgba(255,255,255,0.28); text-transform:uppercase; display:flex; align-items:center; gap:8px; }
  .setting-section::after { content:''; flex:1; height:1px; background:rgba(255,255,255,0.07); }
  .setting-item { display:flex; align-items:center; justify-content:space-between; padding:9px 18px; color:rgba(255,255,255,0.8); font-size:13.5px; cursor:pointer; transition:background .12s; gap:14px; position:relative; }
  .setting-item:hover { background:rgba(0,255,0,0.07); }
  .setting-item .val { color:var(--ea-green); font-size:13px; font-weight:700; }
  .setting-item.active-item { color:var(--ea-green); }
  .setting-item .q-res { font-size:10px; color:rgba(255,255,255,0.35); font-family:'Roboto Mono',monospace; font-weight:500; }
  .setting-item .q-badge { font-size:9px; font-weight:700; padding:2px 5px; border-radius:4px; letter-spacing:.5px; }
  .q-hd { background:rgba(0,255,0,0.12); color:var(--ea-green); border:1px solid rgba(0,255,0,0.25); }
  .q-4k { background:rgba(0,255,0,0.18); color:#fff; border:1px solid rgba(0,255,0,0.35); }
  .q-sd { background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.5); border:1px solid rgba(255,255,255,0.1); }
  .speed-pills { display:flex; flex-wrap:wrap; gap:6px; padding:8px 14px 12px; }
  .speed-pill { flex:1; min-width:52px; background:transparent; border:1px solid rgba(0,255,0,0.15); color:rgba(255,255,255,0.75); font-size:12px; font-weight:600; padding:7px 4px; border-radius:9px; text-align:center; cursor:pointer; transition:background .14s, border-color .14s, color .14s, transform .1s; }
  .speed-pill:hover { background:rgba(0,255,0,0.1); border-color:rgba(0,255,0,0.35); color:#fff; }
  .speed-pill:active { transform:scale(0.94); }
  .speed-pill.active-speed { background:rgba(0,255,0,0.15); border-color:rgba(0,255,0,0.6); color:var(--ea-green); box-shadow:0 0 14px rgba(0,255,0,0.2); }
  #enhance-ctrl { display: flex; align-items: center; justify-content: space-between; padding: 9px 18px; cursor: pointer; gap: 12px; transition: background .12s; }
  #enhance-ctrl:hover { background: rgba(0,255,0,0.07); }
  .ec-left { display: flex; align-items: center; gap: 9px; }
  .ec-icon { font-size: 14px; line-height: 1; color: rgba(255,255,255,0.45); }
  .ec-text { display: flex; flex-direction: column; gap: 1px; }
  .ec-name { font-size: 13.5px; color: rgba(255,255,255,0.8); font-weight: 600; }
  .ec-sub  { font-size: 10px; color: rgba(255,255,255,0.30); font-weight: 500; }
  .ec-pill { font-size: 10px; font-weight: 800; letter-spacing: .6px; padding: 3px 9px; border-radius: 6px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10); color: rgba(255,255,255,0.35); transition: background .15s, color .15s, border-color .15s; }
  #enhance-ctrl.active .ec-icon { color: var(--ea-green); }
  #enhance-ctrl.active .ec-name { color: #fff; }
  #enhance-ctrl.active .ec-pill { background: rgba(0,255,0,0.12); border-color: rgba(0,255,0,0.40); color: var(--ea-green); }

  /* ── CAST & PIP ── */
  #cast-btn, #pip-btn { background: transparent; border: none; cursor: pointer; padding: 8px; border-radius: 11px; display: flex; align-items: center; justify-content: center; transition: opacity .15s, transform .12s, color .15s; flex-shrink: 0; color: rgba(255,255,255,0.85); }
  #cast-btn { opacity: 0.30; pointer-events: none; }
  #cast-btn svg, #pip-btn svg { width: 20px; height: 20px; display: block; }
  #cast-btn.available { opacity: 1; pointer-events: auto; }
  #cast-btn.available:hover, #pip-btn:hover { background: rgba(0,255,0,0.08); transform: scale(1.09); color: #fff; }
  #cast-btn:active, #pip-btn:active { transform: scale(0.93); }
  #cast-btn.casting, #pip-btn.pip-active { color: #00FF00; box-shadow: 0 0 10px rgba(0,255,0,0.35); }
  #pip-btn.pip-unsupported { opacity: 0.25; pointer-events: none; }

  #enhance-toast { position:absolute; top:18px; left:50%; transform:translateX(-50%) translateY(-6px); background:rgba(6,8,20,0.88); backdrop-filter:blur(16px); border:1px solid rgba(255,255,255,0.12); border-radius:12px; padding:8px 18px; color:#fff; font-size:12px; font-weight:600; white-space:nowrap; z-index:40; opacity:0; pointer-events:none; transition: opacity .3s, transform .3s; display:flex; align-items:center; gap:8px; }
  #enhance-toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
  #enhance-toast .et-dot { width:8px; height:8px; border-radius:50%; background:var(--accent2); flex-shrink:0; }
  #enhance-canvas { display:none !important; }

  /* ── IFRAME & VIDEOJS MODE ── */
  #iframe-wrap { position: absolute; inset: 0; z-index: 4; background: transparent; display: none; }
  #iframe-wrap.active { display: block; }
  #iframe-player { width: 100%; height: 100%; border: none; display: block; background: transparent; }
  #vjs-video, .video-js .vjs-big-play-button, .video-js .vjs-control-bar, .video-js .vjs-loading-spinner, .video-js .vjs-text-track-display, .video-js .vjs-error-display { display: none !important; }
  #player.iframe-mode .grad-top, #player.iframe-mode .grad-bottom { display: none !important; }
  @media(min-width:901px){ #player.iframe-mode #fs-btn { display: none !important; } }
  #lang-switcher { display: none !important; }
  #player.iframe-mode { background: transparent !important; pointer-events: none; }
  #player.iframe-mode #sx-logo, #player.iframe-mode #dt-left, #player.iframe-mode #dt-right, #player.iframe-mode #seek-popup-left, #player.iframe-mode #seek-popup-right, #player.iframe-mode #spinner, #player.iframe-mode #stream-loading, #player.iframe-mode #cast-overlay { pointer-events: none !important; display: none !important; }
  #player.iframe-mode #iframe-wrap, #player.iframe-mode #controls { pointer-events: all !important; }
  #player.iframe-mode #lang-switcher { display: block; opacity: 1 !important; pointer-events: all; }
  #player.iframe-mode #skip-back-btn, #player.iframe-mode #skip-fwd-btn, #player.iframe-mode #vol-group, #player.iframe-mode #time-display, #player.iframe-mode #progress-wrap, #player.iframe-mode #rewind-btn, #player.iframe-mode #forward-btn, #player.iframe-mode #live-badge, #player.iframe-mode #speed-badge, #player.iframe-mode #quality-badge, #player.iframe-mode #cc-btn, #player.iframe-mode #cast-btn, #player.iframe-mode #pip-btn, #player.iframe-mode #settings-btn, #player.iframe-mode #play-btn, #player.iframe-mode #enhance-toast, #player.iframe-mode #center-cluster { display: none !important; }
  #player.iframe-mode #ctrl-glass { padding: 4px 4px 6px; }
  #player.iframe-mode #bottom-row { justify-content: flex-end; }
  video { will-change: filter; }

  /* ── CASTING OVERLAY ── */
  #cast-overlay { position:absolute; inset:0; z-index:50; background:rgba(4,6,18,0.96); backdrop-filter:blur(24px); display:none; flex-direction:column; align-items:center; justify-content:center; gap:20px; animation:cast-fadein .35s ease; }
  #cast-overlay.active { display:flex; }
  @keyframes cast-fadein { from{opacity:0;transform:scale(0.97)} to{opacity:1;transform:none} }
  #cast-overlay .co-icon { width:72px; height:72px; border-radius:50%; background:rgba(56,189,248,0.12); border:1.5px solid rgba(56,189,248,0.35); display:flex; align-items:center; justify-content:center; box-shadow:0 0 40px rgba(56,189,248,0.25); animation:cast-pulse 2.4s ease-in-out infinite; }
  @keyframes cast-pulse { 0%,100%{ box-shadow:0 0 30px rgba(56,189,248,0.2); } 50%{ box-shadow:0 0 55px rgba(56,189,248,0.45); } }
  #cast-overlay .co-icon svg { width:34px; height:34px; fill:#38bdf8; }
  #cast-overlay .co-title { font-size:18px; font-weight:700; color:#fff; letter-spacing:.2px; }
  #cast-overlay .co-device { font-size:13px; color:rgba(255,255,255,0.45); font-weight:500; margin-top:-12px; }
  #cast-overlay .co-line { width:48px; height:1.5px; background:linear-gradient(90deg, transparent, rgba(56,189,248,0.5), transparent); }
  #cast-stop-btn { margin-top:6px; background:rgba(244,63,94,0.1); border:1.5px solid rgba(244,63,94,0.35); color:#f43f5e; font-size:13px; font-weight:700; letter-spacing:.4px; padding:11px 28px; border-radius:12px; cursor:pointer; transition:background .15s, transform .12s, box-shadow .15s; }
  #cast-stop-btn:hover { background:rgba(244,63,94,0.22); box-shadow:0 0 20px rgba(244,63,94,0.3); }
  #cast-stop-btn:active { transform:scale(0.95); }
  #cast-overlay .co-note { font-size:12px; color:rgba(255,255,255,0.35); font-weight:400; text-align:center; line-height:1.6; max-width:290px; }
  .seek-popup { position:absolute; background:rgba(6,10,24,0.78); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.13); color:#fff; font-size:13px; font-weight:700; padding:6px 15px; border-radius:22px; pointer-events:none; opacity:0; z-index:22; transition:opacity .18s; white-space:nowrap; font-family:'Roboto Mono',monospace; }
  .seek-popup.show { opacity:1; }
  #seek-popup-left  { top:50%; left:14%; transform:translateY(-50%); }
  #seek-popup-right { top:50%; right:14%; transform:translateY(-50%); }

  /* ── RESPONSIVE / MOBILE ── */
  #controls { padding-left: max(12px, env(safe-area-inset-left, 0px)); padding-right: max(12px, env(safe-area-inset-right, 0px)); padding-bottom: max(12px, env(safe-area-inset-bottom, 12px)); }
  @media (max-width: 768px) {
    #player:not([data-fs="1"]) #controls { bottom: 0; padding-bottom: max(56px, env(safe-area-inset-bottom, 56px)); }
    #player[data-fs="1"] #controls { bottom: 0 !important; top: auto !important; margin-top: 0 !important; padding-bottom: max(12px, env(safe-area-inset-bottom, 12px)) !important; }
    #settings-panel { bottom: 80px; right: max(8px, env(safe-area-inset-right, 8px)); max-height: 60vh; }
    #player[data-fs="1"] #settings-panel { bottom: 72px; max-height: 65vh; }
  }
  .ctrl-btn { padding: clamp(6px, 1.8vw, 10px); border-radius: clamp(8px, 2vw, 12px); }
  .ctrl-btn svg { width: clamp(16px, 4.2vw, 22px); height: clamp(16px, 4.2vw, 22px); }
