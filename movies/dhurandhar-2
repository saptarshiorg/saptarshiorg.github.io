async function fetchStreamsFromSheets() {
  const queryUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&gid=${SHEET_GID}`;
  try {
    const res = await fetch(queryUrl, { cache: 'no-cache' });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const raw = await res.text();
    const json = JSON.parse(raw.match(/google\.visualization\.Query\.setResponse\(([\s\S]*)\)/)[1]);
    const table = json.table;
    if (!table || !table.rows || table.rows.length === 0) throw new Error('Sheet is empty');
    const colLabels = table.cols.map(c => (c.label || c.id || '').toLowerCase().trim());
    const cCode = colLabels.indexOf('lang_code');
    const cLabel = colLabels.indexOf('lang_label');
    const cUrl = colLabels.indexOf('stream_url');
    const cActive = colLabels.indexOf('active');
    if (cCode < 0 || cUrl < 0) throw new Error('Sheet missing required columns');
    const parsed = [];
    for (const row of table.rows) {
      const cells = row.c || [];
      const getVal = i => (i >= 0 && cells[i] && cells[i].v !== null && cells[i].v !== undefined) ? String(cells[i].v).trim() : '';
      const code = getVal(cCode).toUpperCase();
      const url = getVal(cUrl);
      if (!code || !url || url.startsWith('https://your-')) continue;
      const activeRaw = getVal(cActive).toUpperCase();
      if (activeRaw === 'FALSE') continue;
      const cType = colLabels.indexOf('stream_type');
      parsed.push({
        lang_code: code,
        lang_label: getVal(cLabel) || code,
        stream_url: url,
        stream_type: cType >= 0 ? (getVal(cType).toLowerCase() || 'hls') : 'hls',
        active: true,
      });
    }
    if (parsed.length === 0) throw new Error('No active streams found');
    return parsed;
  } catch (err) {
    try {
      const csvUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv&gid=${SHEET_GID}`;
      const res2 = await fetch(csvUrl, { cache: 'no-cache' });
      if (!res2.ok) throw new Error('CSV HTTP ' + res2.status);
      const text = await res2.text();
      const rows = text.trim().split('\n').map(r => parseCSVRow(r));
      if (rows.length < 2) throw new Error('CSV empty');
      const headers = rows[0].map(h => h.toLowerCase().trim());
      const cCode = headers.indexOf('lang_code');
      const cLabel = headers.indexOf('lang_label');
      const cUrl = headers.indexOf('stream_url');
      const cActive = headers.indexOf('active');
      if (cCode < 0 || cUrl < 0) throw new Error('CSV missing columns');
      const parsed2 = [];
      for (let i = 1; i < rows.length; i++) {
        const row = rows[i];
        const code = (row[cCode] || '').trim().toUpperCase();
        const url = (row[cUrl] || '').trim();
        if (!code || !url || url.startsWith('https://your-')) continue;
        const activeRaw = cActive >= 0 ? (row[cActive] || '').trim().toUpperCase() : 'TRUE';
        if (activeRaw === 'FALSE') continue;
        const cType2 = headers.indexOf('stream_type');
        parsed2.push({ lang_code: code, lang_label: (row[cLabel] || code).trim(), stream_url: url, stream_type: (cType2 >= 0 ? (row[cType2] || 'hls').trim().toLowerCase() : 'hls'), active: true });
      }
      if (parsed2.length === 0) throw new Error('No valid rows');
      return parsed2;
    } catch (err2) {
      showCmsError('Could not load streams from sheet — using defaults.');
      return null;
    }
  }
}

function parseCSVRow(row) {
  const result = [];
  let cur = '', inQ = false;
  for (let i = 0; i < row.length; i++) {
    const ch = row[i];
    if (ch === '"') {
      if (inQ && row[i+1] === '"') { cur += '"'; i++; } else inQ = !inQ;
    } else if (ch === ',' && !inQ) { result.push(cur); cur = ''; } else cur += ch;
  }
  result.push(cur);
  return result;
}

