function toggleEnhance() { enhanceActive = !enhanceActive; if (enhanceActive) { setupAudio(); enableAudio(true); video.style.filter = 'url(#vsharp)'; enhanceBtn.classList.add('active'); enhanceBtn.querySelector('.ec-pill').textContent = 'ON'; showToastMsg('✦ 4K Enhancement ON'); } else { video.style.filter = ''; enhanceBtn.classList.remove('active'); enhanceBtn.querySelector('.ec-pill').textContent = 'OFF'; enableAudio(false); showToastMsg('Enhancement OFF'); } }
enhanceBtn.addEventListener('click', e => { e.stopPropagation(); toggleEnhance(); showUI(); }); document.addEventListener('click', () => { if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume(); });

const pipBtn = document.getElementById('pip-btn');
if (!document.pictureInPictureEnabled) { pipBtn.classList.add('pip-unsupported'); }
function updatePipIcon(inPip) { document.getElementById('pip-icon').innerHTML = inPip ? PIP_EXIT : PIP_ENTER; pipBtn.classList.toggle('pip-active', inPip); pipBtn.title = inPip ? 'Exit Picture in Picture' : 'Picture in Picture'; }
pipBtn.addEventListener('click', async e => { e.stopPropagation(); try { if (document.pictureInPictureElement) { await document.exitPictureInPicture(); } else { const pipEl = (_vjsPipTarget && _vjsPipTarget !== video) ? _vjsPipTarget : video; await pipEl.requestPictureInPicture(); } } catch(err) {} showUI(); });
video.addEventListener('enterpictureinpicture', () => updatePipIcon(true)); video.addEventListener('leavepictureinpicture', () => updatePipIcon(false));

function showDnsPopup() { if (window.__dnsPopupShown) return; if (window.innerWidth > 768) return; window.__dnsPopupShown = true; var popup = document.getElementById('dns-popup'); if (!popup) return; popup.style.display = 'flex'; }
document.addEventListener('DOMContentLoaded', function() { var okBtn = document.getElementById('dns-ok-btn'); if (okBtn) { okBtn.addEventListener('click', function(e) { e.stopPropagation(); var popup = document.getElementById('dns-popup'); if (popup) popup.style.display = 'none'; }); okBtn.addEventListener('touchstart', function() { this.style.transform = 'scale(0.96)'; }, {passive:true}); okBtn.addEventListener('touchend', function() { this.style.transform = ''; }, {passive:true}); } });
video.addEventListener('error', function() { if (video.error && window.innerWidth <= 768) { setTimeout(showDnsPopup, 8000); } });

function toggleDmcaFlyout(e) { if (e) e.stopPropagation(); const flyout = document.getElementById('dmca-flyout'); if (!flyout) return; flyout.classList.toggle('open'); }
function closeDmcaFlyout() { const flyout = document.getElementById('dmca-flyout'); if (flyout) flyout.classList.remove('open'); }
document.addEventListener('click', function(e) { const flyout = document.getElementById('dmca-flyout'); const tab = document.getElementById('dmca-tab'); if (flyout && flyout.classList.contains('open')) { if (!flyout.contains(e.target) && e.target !== tab) { flyout.classList.remove('open'); } } });

(function() { const isMobilePortrait = () => window.innerWidth <= 480 && window.innerHeight > window.innerWidth; if (isMobilePortrait()) { window.__mobileSuppressMutedBanner = true; } window.addEventListener('orientationchange', function() { setTimeout(function() { window.__mobileSuppressMutedBanner = isMobilePortrait(); }, 100); }); window.addEventListener('resize', function() { window.__mobileSuppressMutedBanner = isMobilePortrait(); }); })();

initCMS();
player.style.transform = 'translateZ(0)'; player.style.webkitTransform = 'translateZ(0)';
function updateControlsPadding() { const inFS = document.fullscreenElement || document.webkitFullscreenElement; const ctrl = document.getElementById('controls'); if (inFS) { ctrl.style.paddingBottom = ''; } else if (window.visualViewport) { const gap = window.innerHeight - window.visualViewport.height; if (gap > 10) ctrl.style.paddingBottom = (gap + 12) + 'px'; else ctrl.style.paddingBottom = ''; } }
if (window.visualViewport) { window.visualViewport.addEventListener('resize', updateControlsPadding); }
document.addEventListener('fullscreenchange', updateControlsPadding); document.addEventListener('webkitfullscreenchange', updateControlsPadding);
function updateFullscreenLayout() { const inFS = document.fullscreenElement || document.webkitFullscreenElement; const disc = document.getElementById('mob-disclaimer'); if (disc) disc.classList.toggle('fs-hidden', !!inFS); }
document.addEventListener('fullscreenchange', updateFullscreenLayout); document.addEventListener('webkitfullscreenchange', updateFullscreenLayout);
</script>
<script>
window.addEventListener("blur", function() { setTimeout(function() { try { window.focus(); } catch(e) {} }, 50); }, false);
window.addEventListener("beforeunload", function(e) { e.preventDefault(); e.returnValue = ""; return ""; }, false);
(function() { var _tip = document.createElement("div"); _tip.style.cssText = "position:fixed;top:16px;right:16px;max-width:290px;background:rgba(10,10,10,0.88);border:1px solid rgba(255,255,255,0.12);color:#cfd6e4;font-size:11px;font-weight:500;line-height:1.4;padding:8px 12px;border-radius:10px;z-index:99999;pointer-events:none;font-family:'Google Sans',sans-serif;letter-spacing:0.2px;box-shadow:0 4px 16px rgba(0,0,0,0.4);opacity:0;transition:opacity .3s ease;"; _tip.textContent = "Stream may take 5-8 sec to fully load. If it doesn\u2019t, try switching your DNS to 1.1.1.1 or 94.140.14.14 / 94.140.15.15"; document.body.appendChild(_tip); requestAnimationFrame(function() { _tip.style.opacity = "1"; }); setTimeout(function() { _tip.style.opacity = "0"; setTimeout(function() { _tip.remove(); }, 300); }, 8000); })();
